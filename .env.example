# ─── Atlassian OAuth 2.0 (3LO) credentials ───────────────────────────────────
# Register your app at https://developer.atlassian.com/console/myapps/
# Required for the OAuth authorization flow (GET /api/oauth/authorize)
ATLASSIAN_CLIENT_ID=your-client-id-here

# Required for the token exchange step (GET /api/oauth/callback)
ATLASSIAN_CLIENT_SECRET=your-client-secret-here

# ─── OAuth redirect URI ────────────────────────────────────────────────────────
# Must match exactly what is registered in the Atlassian developer console.
# podman-compose path (Caddy TLS sidecar on :8443):
#   OAUTH_REDIRECT_URI=https://localhost:8443/api/oauth/callback
# plain npm path (Caddy local TLS on default :443):
#   OAUTH_REDIRECT_URI=https://localhost/api/oauth/callback
OAUTH_REDIRECT_URI=https://localhost:8443/api/oauth/callback

# ─── Server ───────────────────────────────────────────────────────────────────
# API server port — the Express server binds to this port (default: 4000)
PORT=4000

# ─── Storage (optional overrides) ─────────────────────────────────────────────
# SQLite database file path (default: data/jira_workload.db relative to project root)
# Set to an absolute path to redirect the database to a persistent volume.
# DB_PATH=data/jira_workload.db

# Attachment binary storage directory (default: data/attachments relative to project root)
# Set to an absolute path to redirect storage to an external volume.
# DCC_ATTACHMENT_DIR=data/attachments
